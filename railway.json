{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "chmod +x mvnw && ./mvnw package -DskipTests -q"
  },
  "deploy": {
    "startCommand": "java -Xmx400m -Xms200m -XX:+UseContainerSupport -Dserver.port=$PORT -Dspring.profiles.active=prod -jar target/RiskOperationCenter-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/api/webhook/quicknode/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
