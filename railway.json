{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "chmod +x mvnw && ./mvnw package -DskipTests -q"
  },
  "deploy": {
    "startCommand": "java -Xmx400m -Xms150m -XX:+UseContainerSupport -XX:+UseG1GC -XX:G1HeapRegionSize=4m -XX:MaxMetaspaceSize=110m -XX:ReservedCodeCacheSize=64m -XX:MaxDirectMemorySize=64m -XX:+UseStringDeduplication -XX:+ExplicitGCInvokesConcurrent -Dserver.port=$PORT -Dspring.profiles.active=prod -jar target/RiskOperationCenter-0.0.1-SNAPSHOT.jar",
    "healthcheckPath": "/api/webhook/quicknode/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
